# GoS configuration
GOS_WORKING_DIR=./gos_workspace
GOS_PREBUILT_WORKING_DIR=
GOS_LLM_MODEL=gemini/gemini-3.1-flash-lite-preview
GOS_EMBEDDING_MODEL=gemini/gemini-embedding-001
GOS_EMBEDDING_DIM=3072

# API keys
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter embedding example
# GOS_EMBEDDING_MODEL=openai/text-embedding-3-large
# GOS_EMBEDDING_DIM=3072
# OPENAI_API_KEY=your-openrouter-api-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Retrieval defaults
GOS_LINK_TOP_K=8
GOS_SEED_TOP_K=5
GOS_RETRIEVAL_TOP_N=8
GOS_MAX_SKILL_CHARS=2400
GOS_MAX_CONTEXT_CHARS=12000
